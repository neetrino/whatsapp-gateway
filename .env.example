# ── Application ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Production URL for this deployment (chat.neetrino.com). For local dev, override with http://localhost:3000.
APP_URL=https://chat.neetrino.com
GATEWAY_PUBLIC_URL=https://chat.neetrino.com

# ── Database (Neon Postgres) ───────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# ── Secrets ────────────────────────────────────────────────────────────────────
# Each secret must be at least 32 characters of high-entropy random data.
COOKIE_SECRET=replace-with-32+char-random-string
JWT_SECRET=replace-with-32+char-random-string
TOKEN_PEPPER=replace-with-32+char-random-string

# ── WAHA ───────────────────────────────────────────────────────────────────────
WAHA_BASE_URL=http://waha:3000
WAHA_API_KEY=replace-with-waha-api-key
# WAHA Core: must be "default". WAHA Plus (multiple sessions): leave unset to use each account's DB session name.
WAHA_SESSION_NAME=default
# Passed to the WAHA container via docker-compose (NOWEB engine). Omit if you configure WAHA elsewhere.
WHATSAPP_DEFAULT_ENGINE=NOWEB
WAHA_WEBHOOK_SECRET=replace-with-webhook-secret

# ── API token format ───────────────────────────────────────────────────────────
API_TOKEN_PREFIX=gw_live

# ── Limits ─────────────────────────────────────────────────────────────────────
MAX_TEXT_LENGTH=4096
MAX_CAPTION_LENGTH=4096
MAX_IMAGE_SIZE_MB=10
MAX_VIDEO_SIZE_MB=50
RATE_LIMIT_SEND=60

# ── Initial admin (used by `npm run prisma:seed`) ──────────────────────────────
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-strong-password
