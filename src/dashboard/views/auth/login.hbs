<section class="card">
  <h1>Neetrino Internal Chat Gateway</h1>
  <p class="meta">Authorized users only.</p>
  <p class="meta">This is not a public WhatsApp login page.</p>
  <p class="meta">Contact: <a href="mailto:info@neetrino.com">info@neetrino.com</a></p>
  {{#if loginError}}
    <p class="form-error" role="alert">{{loginError}}</p>
  {{/if}}
  <form method="post" action="/login" class="form">
    <input type="hidden" name="_csrf" value="{{csrfToken}}" />
    <label>
      Email
      <input type="email" name="email" autocomplete="username" required />
    </label>
    <label>
      Password
      <input type="password" name="password" autocomplete="current-password" required minlength="8" />
    </label>
    <button type="submit" class="primary">Sign in</button>
  </form>
</section>
