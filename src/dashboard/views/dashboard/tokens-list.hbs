<section>
  <h1>API tokens</h1>

  {{#if revealed}}
    <div class="banner">
      <strong>Save this token now.</strong> It will not be shown again.
      <pre class="token-display">{{revealed}}</pre>
    </div>
  {{/if}}

  <table class="data-table">
    <thead>
      <tr>
        <th>Owner</th>
        <th>Name</th>
        <th>Prefix</th>
        <th>Last 4</th>
        <th>Last used</th>
        <th>Revoked</th>
        <th>Created</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      {{#each tokens}}
        <tr>
          <td>{{this.ownerEmail}}</td>
          <td>{{this.name}}</td>
          <td><code>{{this.tokenPrefix}}</code></td>
          <td><code>…{{this.last4}}</code></td>
          <td>{{#if this.lastUsedAt}}{{this.lastUsedAt}}{{else}}—{{/if}}</td>
          <td>{{#if this.revokedAt}}Yes{{else}}No{{/if}}</td>
          <td>{{this.createdAt}}</td>
          <td>
            {{#unless this.revokedAt}}
              <form method="post" action="/tokens/{{this.id}}/revoke" class="inline">
                <input type="hidden" name="_csrf" value="{{../csrfToken}}" />
                <button type="submit" class="danger">Revoke</button>
              </form>
              <form method="post" action="/tokens/{{this.id}}/regenerate" class="inline">
                <input type="hidden" name="_csrf" value="{{../csrfToken}}" />
                <button type="submit">Regenerate</button>
              </form>
            {{/unless}}
          </td>
        </tr>
      {{/each}}
    </tbody>
  </table>
</section>
