<section>
  <div class="page-header">
    <h1>Users</h1>
    <a href="/users/new" class="primary">New user</a>
  </div>
  <table class="data-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Role</th>
        <th>Active</th>
        <th>WhatsApp status</th>
        <th>Created</th>
      </tr>
    </thead>
    <tbody>
      {{#each users}}
        <tr>
          <td><a href="/users/{{this.id}}">{{this.name}}</a></td>
          <td>{{this.email}}</td>
          <td>{{this.role}}</td>
          <td>{{#if this.isActive}}Yes{{else}}No{{/if}}</td>
          <td>{{#if this.whatsappAccount}}{{this.whatsappAccount.status}}{{else}}—{{/if}}</td>
          <td>{{this.createdAt}}</td>
        </tr>
      {{/each}}
    </tbody>
  </table>
</section>
