{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      { "include": "dashboard/views/**/*", "outDir": "dist" },
      { "include": "dashboard/public/**/*", "outDir": "dist" }
    ],
    "watchAssets": true
  }
}
